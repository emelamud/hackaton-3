PORT=3000
DATABASE_URL=postgresql://chat:chat@postgres:5432/chat
# Generate each independently with: openssl rand -base64 48
# Must be >=32 chars and distinct from each other in production.
JWT_SECRET=replace-with-openssl-rand-base64-48-value-at-least-32c
JWT_REFRESH_SECRET=replace-with-openssl-rand-base64-48-value-at-least-32c
JWT_RESET_SECRET=replace-with-openssl-rand-base64-48-value-at-least-32c
NODE_ENV=development
UPLOADS_DIR=/app/uploads
