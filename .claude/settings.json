{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '\"[\" + (now | todate) + \"] USER: \" + (.prompt | tostring)' >> chat-logs/chat-history.log"
          }
        ]
      }
    ]
  }
}
